            <simpletable>
                <strow>
                    <stentry><b>Dispositif</b></stentry>
                    <stentry><b>Description</b></stentry>
                </strow>
                <strow>
                    <stentry>Lecteur de glycémie</stentry>
                    <stentry>mesure ponctuelle du glucose sanguin</stentry>
                </strow>
                <strow>
                    <stentry>Capteur de glucose en continu</stentry>
                    <stentry>mesure automatique des variations glycémiques</stentry>
                </strow>
                <strow>
                    <stentry>Application mobile associée</stentry>
                    <stentry>consultation des données et alertes</stentry>
                </strow>
            </simpletable>
        </section>
